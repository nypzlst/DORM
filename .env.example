# Шаблон конфига для TestORM. Скопируй в `.env` и заполни своими значениями.
# .env лежит в .gitignore и не попадёт в репозиторий.

# Вариант 1: одна полная строка подключения, прочитанная из файла.
# Если задан DORM_CONN_FILE, остальные DORM_* переменные игнорируются.
# DORM_CONN_FILE=./TestORM/dbconfig.txt

# Вариант 2: раздельные параметры.
DORM_DB=railway
DORM_HOST=localhost
DORM_USER=root
DORM_PASS=
DORM_PORT=3306
